// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id String @id @default(uuid())
  email String @unique
  password String
  name String
  createdAt DateTime @default(now())
  accounts Account[]
  wallet Wallet?
}

model Wallet {
  id String @id @default(uuid())
  balance Decimal @default(0.00) @db.Decimal(12,2)
  currency String @default("MXN")
  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id String @id @default(uuid())
  userId String
  currency String
  balance Decimal @default(0.00) @db.Decimal(18,4)
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  debits LedgerEntry[] @relation("Debits")
  credits LedgerEntry[] @relation("Credits")

  @@unique([userId, currency])

}

model LedgerEntry {
  id String @id @default(uuid())
  description String?
  amount Decimal @db.Decimal(18,4)
  convertedAmount      Decimal  @db.Decimal(18, 4)
  exchangeRate         Decimal  @db.Decimal(18, 4)

  
  senderCurrency       String   // Moneda de la cuenta origen (ej. 'USD')
  receiverCurrency     String   // Moneda de la cuenta destino (ej. 'MXN')

  //Origin
  sourceAccountId String
  sourceAccount Account @relation("Debits", fields: [sourceAccountId], references: [id])

  //Destination
  destinationAccountId String
  destinationAccount Account @relation("Credits", fields: [destinationAccountId], references: [id])

  createdAt DateTime @default(now())

  @@index([sourceAccountId])
  @@index([destinationAccountId])
  @@index([createdAt])
}

